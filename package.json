{
  "name": "imti-iphone-assessment-platform",
  "version": "1.0.0",
  "description": "IMTI: iPhone Assessment Platform",
  "main": "main.js",
  "scripts": {
    "sass:build": "sass src/assets/scss/main.scss src/assets/css/main.css --style=compressed --no-source-map",
    "sass:watch": "sass src/assets/scss/main.scss src/assets/css/main.css --watch",
    "prestart": "npm run sass:build",
    "start": "start-electron.bat",
    "dev": "start-electron.bat development",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": "MezaTech",
  "license": "MIT",
  "dependencies": {
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "pdfkit": "^0.14.0",
    "plist": "^3.1.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "sass": "^1.98.0"
  },
  "build": {
    "appId": "com.imti.assessment-platform",
    "productName": "IMTI: iPhone Assessment Platform",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "engine/**/*",
      "resources/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "runAfterFinish": true,
      "license": "resources/license.txt"
    },
    "win": {
      "extraResources": [
        {
          "from": "resources/bin/win32",
          "to": "bin/win32",
          "filter": [
            "**/*"
          ]
        },
        {
          "from": "resources/python",
          "to": "python",
          "filter": [
            "**/*"
          ]
        }
      ],
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.png",
      "signAndEditExecutable": false,
      "rfc3161TimeStampServer": null
    },
    "mac": {
      "extraResources": [
        {
          "from": "resources/bin/darwin",
          "to": "bin/darwin",
          "filter": [
            "**/*"
          ]
        }
      ],
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icon.png"
    }
  }
}
