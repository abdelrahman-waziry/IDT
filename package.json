{
  "name": "ios-device-manager",
  "version": "1.0.0",
  "description": "iOS Device Manager - Desktop application for iOS device diagnostics",
  "main": "main.js",
  "scripts": {
    "sass:build": "sass src/assets/scss/main.scss src/assets/css/main.css --style=compressed --no-source-map",
    "sass:watch": "sass src/assets/scss/main.scss src/assets/css/main.css --watch",
    "prestart": "npm run sass:build",
    "start": "start-electron.bat",
    "dev": "start-electron.bat development",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": "MezaTech",
  "license": "MIT",
  "dependencies": {
    "localtunnel": "^2.0.2",
    "ngrok": "^5.0.0-beta.2",
    "pdfkit": "^0.14.0",
    "plist": "^3.1.0",
    "qrcode": "^1.5.4",
    "vue": "^3.4.21"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "sass": "^1.98.0"
  },
  "build": {
    "appId": "com.mezatech.ios-device-manager",
    "productName": "iOS Device Manager",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "engine/**/*",
      "resources/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false,
      "rfc3161TimeStampServer": null
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "resources/icon.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "resources/icons"
    }
  }
}
